{
  "name": "xcoorp/laravel-passport-control",
  "description": "Resource Server package for Laravel Passport.",
  "keywords": [
    "laravel",
    "passport",
    "oauth",
    "resource server"
  ],
  "homepage": "https://github.com/xcoorp/laravel-passport-control",
  "license": "MIT",
  "authors": [
    {
      "name": "XCoorp GmbH",
      "homepage": "https://xcoorp.com"
    }
  ],
  "require": {
    "php": "^8.3 || ^8.4 || ^8.5",
    "symfony/psr-http-message-bridge": "^v7.4.4",
    "nyholm/psr7": "^1.8.2",
    "league/oauth2-server": "^9.3.0",
    "illuminate/auth": "^11.0 || ^12.0 || ^13.0",
    "illuminate/contracts": "^11.0 || ^12.0 || ^13.0",
    "illuminate/container": "^11.0 || ^12.0 || ^13.0",
    "illuminate/filesystem": "^11.0 || ^12.0 || ^13.0",
    "illuminate/http": "^11.0 || ^12.0 || ^13.0",
    "illuminate/support": "^11.0 || ^12.0 || ^13.0",
    "illuminate/collections": "^11.0 || ^12.0 || ^13.0",
    "illuminate/config": "^11.0 || ^12.0 || ^13.0",
    "illuminate/macroable": "^11.0 || ^12.0 || ^13.0",
    "lcobucci/jwt": "^5.6.0",
    "psr/http-message": "^2.0",
    "symfony/http-kernel": "^v7.4.7",
    "nesbot/carbon": "^3.11.3"
  },
  "require-dev": {
    "roave/security-advisories": "dev-latest",
    "laravel/pint": "^v1.29.0"
  },
  "autoload": {
    "psr-4": {
      "XCoorp\\PassportControl\\": "src"
    }
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  },
  "scripts": {
    "lint": [
      "./vendor/bin/pint --test"
    ],
    "fix": [
      "./vendor/bin/pint"
    ]
  },
  "extra": {
    "laravel": {
      "providers": [
        "XCoorp\\PassportControl\\PassportControlServiceProvider"
      ]
    }
  }
}
